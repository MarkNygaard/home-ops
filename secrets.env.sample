# Secrets reference template
# Copy this file to .private/secrets.env and fill in your values.
# .private/ is gitignored — never commit the filled-in file.
#
# These values will end up in secret.sops.yaml files throughout the cluster.
# Having them collected here means you don't need to hunt through Docker Compose
# files mid-setup.

# =============================================================================
# CLUSTER-LEVEL (goes into cluster.yaml + cluster-secrets Secret)
# =============================================================================

SECRET_DOMAIN=                        # e.g. mnygaard.io
CLOUDFLARE_TOKEN=                     # Zone:DNS:Edit + Account:Cloudflare Tunnel:Read
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_TOKEN=              # from: cloudflared tunnel create <name>

# =============================================================================
# NETWORKING
# =============================================================================

# AirVPN / Gluetun (WireGuard)
AIRVPN_WIREGUARD_PRIVATE_KEY=
AIRVPN_WIREGUARD_PRESHARED_KEY=
AIRVPN_WIREGUARD_ENDPOINT_IP=
AIRVPN_WIREGUARD_ENDPOINT_PORT=
AIRVPN_WIREGUARD_ADDRESSES=           # IP assigned to you by AirVPN, e.g. 10.x.x.x/32
AIRVPN_FORWARDED_PORT=                # from AirVPN client area → Forwarded Ports

# UniFi
UNIFI_MONGODB_PASSWORD=               # set this yourself — MongoDB password for UniFi
UNIFI_POLLER_PASSWORD=                # UniFi controller local admin password (for unifi-poller)

# =============================================================================
# DATABASES (CloudNativePG)
# =============================================================================

POSTGRES_SUPERUSER_PASSWORD=          # set this yourself
POSTGRES_AUTHENTIK_PASSWORD=          # set this yourself
POSTGRES_N8N_PASSWORD=                # set this yourself
POSTGRES_HOMEASSISTANT_PASSWORD=      # set this yourself
POSTGRES_PROMETHEUS_PASSWORD=         # set this yourself

# =============================================================================
# BACKUP (Cloudflare R2 — Volsync)
# =============================================================================

R2_VOLSYNC_ENDPOINT=                  # https://<account_id>.r2.cloudflarestorage.com
R2_VOLSYNC_BUCKET=                    # e.g. cluster-volsync
R2_VOLSYNC_ACCESS_KEY_ID=
R2_VOLSYNC_SECRET_ACCESS_KEY=

# =============================================================================
# SECURITY & IDENTITY
# =============================================================================

# Authentik
AUTHENTIK_SECRET_KEY=                 # generate with: openssl rand -hex 50

# =============================================================================
# OBSERVABILITY
# =============================================================================

# Ntfy
NTFY_AUTH_TOKEN=                      # set this yourself — used by Gatus + Alertmanager

# =============================================================================
# MEDIA
# =============================================================================

# Radarr / Sonarr / Prowlarr / Bazarr / Jellyfin / Seerr API keys
# Note: these are generated by each app on first boot — fill them in after
# the apps are running (needed for Homepage annotations and cross-app wiring)
RADARR_API_KEY=
SONARR_API_KEY=
PROWLARR_API_KEY=
BAZARR_API_KEY=
JELLYFIN_API_KEY=
SEERR_API_KEY=

# =============================================================================
# AUTOMATION & AI
# =============================================================================

# n8n
N8N_ENCRYPTION_KEY=                   # generate with: openssl rand -hex 32

# OpenAI (Crawl4AI)
OPENAI_API_KEY=
